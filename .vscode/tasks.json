{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run AHAR",
      "type": "shell",
      "command": "C:\\Users\\bhagy\\OneDrive\\Documents\\New project\\AharMealsWithLove\\run-project.bat",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Build AHAR",
      "type": "shell",
      "command": "\"C:\\Program Files\\dotnet\\dotnet.exe\" build",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "DOTNET_CLI_HOME": "${workspaceFolder}\\..\\.dotnet_home",
          "DOTNET_SKIP_FIRST_TIME_EXPERIENCE": "1",
          "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
          "APPDATA": "${workspaceFolder}\\..\\.appdata",
          "LOCALAPPDATA": "${workspaceFolder}\\..\\.localappdata"
        }
      },
      "problemMatcher": "$msCompile"
    }
  ]
}
