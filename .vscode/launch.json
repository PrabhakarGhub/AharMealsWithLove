{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run AHAR Website",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "Build AHAR",
      "program": "C:\\Program Files\\dotnet\\dotnet.exe",
      "args": [
        "run",
        "--no-build",
        "--urls",
        "http://localhost:5098"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "DOTNET_CLI_HOME": "${workspaceFolder}\\..\\.dotnet_home",
        "DOTNET_SKIP_FIRST_TIME_EXPERIENCE": "1",
        "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
        "APPDATA": "${workspaceFolder}\\..\\.appdata",
        "LOCALAPPDATA": "${workspaceFolder}\\..\\.localappdata",
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Now listening on:\\s+(https?://\\S+)"
      }
    }
  ]
}
