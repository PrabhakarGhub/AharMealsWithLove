@model AharMealsWithLove.Models.DonationViewModel
@{ ViewData["Title"] = "Payment Receipt"; }
<div class="page-header"><div class="container"><h1><i class="fa fa-check-circle me-3 text-success"></i>Payment Successful!</h1></div></div>
<div class="container pb-5"><div class="row justify-content-center"><div class="col-md-6">
  <div class="receipt-card" id="receiptArea">
    <div class="receipt-header text-center"><i class="fa fa-check-circle fa-3x mb-2"></i><h4 class="fw-bold">Payment Receipt</h4><p class="opacity-75 mb-0">Transaction Successful</p></div>
    <div class="p-4">
      <table class="table"><tr><th>Billing Address:</th><td>@Model.BillingAddress</td></tr><tr><th>Service:</th><td>@Model.ServiceType</td></tr>
      <tr><th>Amount:</th><td>₹@Model.Amount</td></tr><tr><th>Additional:</th><td>₹0</td></tr>
      <tr class="table-success"><th><strong>Total:</strong></th><td><strong>₹@Model.TotalAmount</strong></td></tr></table>
      <div class="alert alert-success text-center mt-3"><i class="fa fa-heart me-2"></i>Thank you for your donation! You've made a difference.</div>
      <div class="d-flex gap-2 mt-3">
        <button onclick="window.print()" class="btn btn-ahar flex-fill"><i class="fa fa-print me-2"></i>Print</button>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-ahar flex-fill"><i class="fa fa-home me-2"></i>Home</a>
      </div>
    </div>
  </div>
</div></div></div>
