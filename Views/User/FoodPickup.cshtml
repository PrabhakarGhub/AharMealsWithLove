@model AharMealsWithLove.Models.PickupRequest
@{ ViewData["Title"] = "Food Pickup Request"; }
<div class="container-fluid"><div class="row">
  @await Html.PartialAsync("_UserSidebar")
  <div class="col-md-10 py-4">
    <h3 class="fw-bold mb-4"><i class="fa fa-truck text-warning me-2"></i>Food Pickup Request</h3>
    @if(Model.Message != null){ <div class="alert alert-success"><i class="fa fa-check-circle me-2"></i>@Model.Message</div> }
    <div class="ahar-card p-4">
      <div class="alert alert-ahar mb-4"><i class="fa fa-info-circle me-2 text-warning"></i>Please fill in the details below. Our team will contact you shortly.</div>
      <form asp-action="FoodPickup" method="post">
        <div class="row g-3">
          <div class="col-md-6"><label class="form-label fw-bold">Event Details</label><input asp-for="EventDetail" class="form-control form-control-lg" placeholder="e.g. Wedding Reception, Birthday Party"/></div>
          <div class="col-md-6"><label class="form-label fw-bold">Venue / Address</label><input asp-for="Venue" class="form-control form-control-lg" placeholder="Complete address of event venue"/></div>
          <div class="col-md-6"><label class="form-label fw-bold">Date of Event</label><input asp-for="Date" class="form-control form-control-lg" type="date"/></div>
          <div class="col-md-6"><label class="form-label fw-bold">Food Category</label><select asp-for="Category" class="form-select form-select-lg"><option value="veg">Vegetarian</option><option value="nonveg">Non-Vegetarian</option><option value="both">Both</option></select></div>
          <div class="col-md-6"><label class="form-label fw-bold">Quantity (No. of servings)</label><input asp-for="Quantity" class="form-control form-control-lg" placeholder="e.g. 200 plates"/></div>
          <div class="col-md-6"><label class="form-label fw-bold">Cook Time</label><input asp-for="CookTime" class="form-control form-control-lg" placeholder="e.g. 2:00 PM"/></div>
          <div class="col-md-6"><label class="form-label fw-bold">Expected Expiry Time</label><input asp-for="ExpTime" class="form-control form-control-lg" placeholder="e.g. 8:00 PM"/></div>
          <div class="col-md-6"><label class="form-label fw-bold">Area Code</label><select asp-for="AreaCode" class="form-select form-select-lg"><option>110</option><option>112</option><option>114</option></select></div>
          <div class="col-12"><button type="submit" class="btn btn-ahar btn-lg px-5"><i class="fa fa-paper-plane me-2"></i>Submit Pickup Request</button></div>
        </div>
      </form>
    </div>
  </div>
</div></div>
