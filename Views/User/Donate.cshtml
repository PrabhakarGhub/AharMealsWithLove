@{ ViewData["Title"] = "Donate"; }
<div class="page-header"><div class="container"><h1><i class="fa fa-donate me-3 text-warning"></i>Donate</h1></div></div>
<div class="container pb-5">
  <div class="row g-4 align-items-center">
    <div class="col-md-4 text-center"><div class="ahar-card p-4"><i class="fa fa-credit-card fa-4x text-warning mb-3"></i><h4 class="fw-bold">Donate Online</h4><p class="text-muted">Support our mission with an online donation</p><a asp-controller="User" asp-action="ShareBirthday" class="btn btn-ahar btn-lg w-100">Donate Now</a></div></div>
    <div class="col-md-4 text-center"><div class="ahar-card p-4" style="border-top:4px solid var(--ahar-orange)"><h4 class="fw-bold text-warning">We are bringing happiness in many hungry faces by feeding them.</h4><p class="text-muted mt-2">It involves expenses for vehicle, vessels, fuel, staff and maintenance.</p><p class="fw-bold text-ahar">Donate and help bring more smiles!!</p></div></div>
    <div class="col-md-4 text-center"><div class="ahar-card p-4"><i class="fa fa-university fa-4x text-success mb-3"></i><h4 class="fw-bold">Bank Transfer</h4><p class="text-muted">Account Name: No Food Waste<br/>Bank: SBI, Ranchi<br/>Contact us for account details</p><a asp-controller="Home" asp-action="Contact" class="btn btn-success btn-lg w-100">Get Bank Details</a></div></div>
  </div>
</div>
