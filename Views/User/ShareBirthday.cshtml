@model AharMealsWithLove.Models.BirthdayViewModel
@{ ViewData["Title"] = "Share Your Birthday"; }
<div class="page-header"><div class="container"><h1><i class="fa fa-birthday-cake me-3 text-warning"></i>Share Your Birthday</h1></div></div>
<div class="container pb-5"><div class="row justify-content-center"><div class="col-md-7">
  <div class="ahar-card p-4">
    <div class="alert alert-ahar mb-4"><i class="fa fa-heart text-danger me-2"></i>Celebrate your special day by feeding the needy! Your birthday becomes even more meaningful.</div>
    <form asp-action="ShareBirthday" method="post">
      <div class="row g-3">
        <div class="col-md-6"><label class="form-label fw-bold">Your Name</label><input asp-for="Name" class="form-control form-control-lg" placeholder="Full name"/></div>
        <div class="col-md-6"><label class="form-label fw-bold">Email</label><input asp-for="Email" class="form-control form-control-lg" placeholder="Email"/></div>
        <div class="col-md-6"><label class="form-label fw-bold">Mobile</label><input asp-for="Mobile" class="form-control form-control-lg" placeholder="Mobile number"/></div>
        <div class="col-md-6"><label class="form-label fw-bold">Birthday / Anniversary Date</label><input asp-for="DOB" type="date" class="form-control form-control-lg"/></div>
        <div class="col-12"><label class="form-label fw-bold">Address</label><textarea asp-for="Address" class="form-control" rows="2" placeholder="Your address"></textarea></div>
        <div class="col-12"><button type="submit" class="btn btn-ahar btn-lg w-100"><i class="fa fa-arrow-right me-2"></i>Next – Select Capacity</button></div>
      </div>
    </form>
  </div>
</div></div></div>
