@model AharMealsWithLove.Models.ChangePasswordViewModel
@{ ViewData["Title"] = "Change Password"; }
<div class="container-fluid"><div class="row">
  @await Html.PartialAsync("_UserSidebar")
  <div class="col-md-10 py-4"><div class="row justify-content-center"><div class="col-md-6">
    <h3 class="fw-bold mb-4"><i class="fa fa-key text-warning me-2"></i>Change Password</h3>
    @if(Model.Message != null){ <div class="alert alert-success">@Model.Message</div> }
    <div class="ahar-card p-4">
      <form asp-action="ChangePassword" method="post">
        @if(Context.Session.GetString("uname") != null){
          <div class="mb-3"><label class="form-label fw-bold">Old Password</label><input asp-for="OldPassword" type="password" class="form-control form-control-lg"/></div>
        }
        <div class="mb-3"><label class="form-label fw-bold">New Password</label><input asp-for="Password" type="password" class="form-control form-control-lg"/></div>
        <div class="mb-3"><label class="form-label fw-bold">Confirm Password</label><input asp-for="ConfirmPassword" type="password" class="form-control form-control-lg"/><span asp-validation-for="ConfirmPassword" class="text-danger small"></span></div>
        <button type="submit" class="btn btn-ahar w-100 btn-lg"><i class="fa fa-save me-2"></i>Update Password</button>
      </form>
    </div>
  </div></div></div>
</div></div>
