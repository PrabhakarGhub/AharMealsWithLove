@model List<Dictionary<string,string>>
@{ ViewData["Title"] = "My Pickups"; }
<div class="container-fluid"><div class="row">
  @await Html.PartialAsync("_UserSidebar")
  <div class="col-md-10 py-4">
    <h3 class="fw-bold mb-4"><i class="fa fa-list text-warning me-2"></i>My Pickup Requests</h3>
    <div class="ahar-card p-4">
      @if(Model != null && Model.Count > 0){
        <div class="table-responsive"><table class="table ahar-table">
          <thead><tr><th>#</th><th>Event</th><th>Venue</th><th>Date</th><th>Category</th><th>Qty</th><th>Status</th></tr></thead>
          <tbody>@foreach(var p in Model){
            <tr><td>@p.GetValueOrDefault("ID","–")</td><td>@p.GetValueOrDefault("eventdetail","–")</td><td>@p.GetValueOrDefault("venue","–")</td>
            <td>@p.GetValueOrDefault("date","–")</td><td>@p.GetValueOrDefault("category","–")</td><td>@p.GetValueOrDefault("quantity","–")</td>
            <td><span class="badge badge-@p.GetValueOrDefault("status","submitted").ToLower()">@p.GetValueOrDefault("status","Submitted")</span></td></tr>
          }</tbody>
        </table></div>
      } else { <div class="alert alert-info text-center"><i class="fa fa-info-circle me-2"></i>No pickup requests yet. <a asp-action="FoodPickup" class="alert-link">Request a pickup</a></div> }
    </div>
  </div>
</div></div>
