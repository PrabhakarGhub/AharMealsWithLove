@model AharMealsWithLove.Models.PaymentViewModel
@{ ViewData["Title"] = "Payment Gateway"; }
<div class="page-header"><div class="container"><h1><i class="fa fa-lock me-3 text-warning"></i>Secure Payment</h1></div></div>
<div class="container pb-5"><div class="row justify-content-center"><div class="col-md-6">
  <div class="ahar-card overflow-hidden">
    <div class="p-3" style="background:linear-gradient(135deg,#1a1a2e,#16213e);color:#fff;"><div class="d-flex align-items-center gap-2"><i class="fa fa-credit-card fa-2x text-warning"></i><div><div class="fw-bold">Card Payment</div><div class="small opacity-75">Secure 256-bit SSL Encrypted</div></div></div></div>
    <div class="p-4">
      @if(Model.ErrorMessage != null){ <div class="alert alert-danger">@Model.ErrorMessage</div> }
      <form asp-action="Gateway" method="post">
        <div class="mb-3"><label class="form-label fw-bold">Card Number</label><input asp-for="CardNumber" class="form-control form-control-lg" placeholder="0000 0000 0000 0000" maxlength="16"/></div>
        <div class="row g-2 mb-3"><div class="col-6"><label class="form-label fw-bold">Expiry (MM/YY)</label><input asp-for="Expiry" class="form-control form-control-lg" placeholder="MM/YY"/></div>
        <div class="col-6"><label class="form-label fw-bold">CVV</label><input asp-for="CVV" type="password" class="form-control form-control-lg" placeholder="•••" maxlength="3"/></div></div>
        <div class="mb-3"><label class="form-label fw-bold">Card Holder Name</label><input asp-for="CardName" class="form-control form-control-lg" placeholder="Name on card"/></div>
        <button type="submit" class="btn btn-success btn-lg w-100"><i class="fa fa-lock me-2"></i>Process Payment</button>
      </form>
    </div>
  </div>
</div></div></div>
