@model Dictionary<string,string>
@{ ViewData["Title"] = "Print Profile"; Layout = "_Layout"; }
<div class="container-fluid"><div class="row">
  @await Html.PartialAsync("_UserSidebar")
  <div class="col-md-10 py-4">
    <h3 class="fw-bold mb-4"><i class="fa fa-print text-warning me-2"></i>Print Profile</h3>
    <div class="ahar-card p-4" id="printArea">
      @if(Model != null){
        <div class="row g-3">
          @if(!string.IsNullOrEmpty(Model.GetValueOrDefault("Image",""))){
            <div class="col-12 text-center mb-3">
              <img src="@Model["Image"]" class="rounded-circle" style="width:120px;height:120px;object-fit:cover;" onerror="this.style.display='none'"/>
            </div>
          } else {
            <div class="col-12 text-center mb-3">
              <div class="rounded-circle bg-warning d-inline-flex align-items-center justify-content-center" style="width:100px;height:100px;">
                <i class="fa fa-user fa-3x text-dark"></i>
              </div>
            </div>
          }
          @foreach(var field in new[]{
            ("Name", Model.GetValueOrDefault("Name","–")),
            ("Email", Model.GetValueOrDefault("Email","–")),
            ("Gender", Model.GetValueOrDefault("Gender","–")),
            ("Date of Birth", Model.GetValueOrDefault("DOB","–")),
            ("Phone", Model.GetValueOrDefault("Phone","–")),
            ("Aadhar", Model.GetValueOrDefault("Aadhar","–")),
            ("Address", Model.GetValueOrDefault("Address","–")),
            ("Area Code", Model.GetValueOrDefault("AreaCode","–"))
          }){
            <div class="col-md-6">
              <div class="p-3 bg-light rounded-3">
                <div class="text-muted small fw-bold">@field.Item1</div>
                <div class="fw-bold mt-1">@field.Item2</div>
              </div>
            </div>
          }
        </div>
        <div class="d-flex gap-3 mt-4">
          <button onclick="window.print()" class="btn btn-ahar btn-lg"><i class="fa fa-print me-2"></i>Print</button>
          <a asp-action="Profile" class="btn btn-outline-ahar btn-lg"><i class="fa fa-edit me-2"></i>Edit Profile</a>
        </div>
      } else {
        <div class="alert alert-warning">Profile not found. Please <a asp-action="Profile">complete your profile</a> first.</div>
      }
    </div>
  </div>
</div></div>
@section Scripts {
<style>
  @@media print {
    .dash-sidebar, nav.ahar-nav, footer, .btn, .ahar-nav { display: none !important; }
    #printArea { box-shadow: none !important; }
  }
</style>
}
