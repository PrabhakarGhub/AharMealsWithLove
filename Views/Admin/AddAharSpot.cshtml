@model AharMealsWithLove.Models.AharSpotViewModel
@{ ViewData["Title"] = "Add Ahar Spot"; }
<div class="container-fluid"><div class="row">
  @await Html.PartialAsync("_AdminSidebar")
  <div class="col-md-10 py-4">
    <h3 class="fw-bold mb-4"><i class="fa fa-map-marker-alt text-warning me-2"></i>Add Ahar Spot</h3>
    @if(Model.Message != null){ <div class="alert alert-success"><i class="fa fa-check-circle me-2"></i>@Model.Message</div> }
    <div class="ahar-card p-4">
      <form asp-action="AddAharSpot" method="post">
        <div class="row g-3">
          <div class="col-md-6"><label class="form-label fw-bold">Area Category</label>
            <select asp-for="Category" class="form-select form-select-lg"><option>Urban</option><option>Rural</option><option>Others</option></select></div>
          <div class="col-md-6"><label class="form-label fw-bold">Type of People</label>
            <select asp-for="Type" class="form-select form-select-lg">
              <option>Economically Backward Slums</option><option>Orphanages</option><option>Old Age Homes</option>
              <option>Homeless People</option><option>Shelter Homes</option><option>Rural Communities</option><option>Others</option>
            </select></div>
          <div class="col-12"><label class="form-label fw-bold">Address</label><input asp-for="Address" class="form-control form-control-lg" placeholder="Complete address"/></div>
          <div class="col-md-6"><label class="form-label fw-bold">Approx. No. of People</label><input asp-for="NoPeople" class="form-control form-control-lg" placeholder="e.g. 200"/></div>
          <div class="col-12"><button type="submit" class="btn btn-ahar btn-lg px-5"><i class="fa fa-save me-2"></i>Add Ahar Spot</button></div>
        </div>
      </form>
    </div>
  </div>
</div></div>
