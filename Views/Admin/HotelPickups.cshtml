@model List<Dictionary<string,string>>
@{ ViewData["Title"] = "Hotel Pickups"; }
<div class="container-fluid"><div class="row">
  @await Html.PartialAsync("_AdminSidebar")
  <div class="col-md-10 py-4">
    <h3 class="fw-bold mb-4"><i class="fa fa-hotel text-success me-2"></i>Hotel Pickup Requests</h3>
    <div class="ahar-card p-3">
      <div class="table-responsive"><table class="table ahar-table">
        <thead><tr><th>#</th><th>Hotel</th><th>Email</th><th>Event</th><th>Venue</th><th>Date</th><th>Qty</th><th>Status</th><th>Action</th></tr></thead>
        <tbody>
          @if(Model.Count > 0){ foreach(var p in Model){
            <tr><td>@p["ID"]</td><td>@p.GetValueOrDefault("uname","–")</td><td>@p.GetValueOrDefault("Email","–")</td>
            <td>@p.GetValueOrDefault("eventdetail","–")</td><td>@p.GetValueOrDefault("venue","–")</td>
            <td>@p.GetValueOrDefault("date","–")</td><td>@p.GetValueOrDefault("quantity","–")</td>
            <td><span class="badge badge-@p.GetValueOrDefault("status","submitted").ToLower()">@p.GetValueOrDefault("status","–")</span></td>
            <td><form asp-action="UpdateHotelPickupStatus" method="post" class="d-flex gap-1">
              <input type="hidden" name="id" value="@p["ID"]"/>
              <button name="status" value="Accept" class="btn btn-sm btn-success">Accept</button>
              <button name="status" value="Reject" class="btn btn-sm btn-danger">Reject</button>
            </form></td></tr>
          }} else { <tr><td colspan="9" class="text-center text-muted">No hotel pickup requests.</td></tr> }
        </tbody>
      </table></div>
    </div>
  </div>
</div></div>
