@model AharMealsWithLove.Models.SignupViewModel
@{ ViewData["Title"] = "Forgot Password"; bool otpSent = Model.OtpSent; }
<div class="page-header"><div class="container"><h1><i class="fa fa-key me-3 text-warning"></i>Forgot Password</h1></div></div>
<div class="container pb-5"><div class="row justify-content-center"><div class="col-md-5">
  <div class="ahar-card p-4">
    @if(Model.Message != null){ <div class="alert @(Model.Message.Contains("OTP") || Model.Message.Contains("Please") ? "alert-success" : "alert-danger")">@Model.Message</div> }
    <form asp-action="ForgotPassword" method="post">
      <input type="hidden" name="OtpSent" value="@otpSent"/>
      <div class="mb-3"><label class="form-label fw-bold">Registered Email</label>
        @if(otpSent){ <input asp-for="Email" class="form-control form-control-lg" readonly/> }
        else { <input asp-for="Email" class="form-control form-control-lg" placeholder="Enter your registered email"/> }
      </div>
      @if(otpSent){
        <div class="mb-3"><label class="form-label fw-bold">OTP</label><input asp-for="OTP" class="form-control form-control-lg" placeholder="Enter OTP"/></div>
        <button name="action" value="verifyotp" class="btn btn-ahar w-100 btn-lg">Verify OTP</button>
      } else {
        <button name="action" value="sendotp" class="btn btn-ahar w-100 btn-lg">Send OTP</button>
      }
    </form>
  </div>
</div></div></div>
