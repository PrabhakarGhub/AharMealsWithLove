@model AharMealsWithLove.Models.LoginViewModel
@{ ViewData["Title"] = "Volunteer Login"; }
<div class="page-header"><div class="container"><h1><i class="fa fa-hands-helping me-3 text-warning"></i>Volunteer Login</h1></div></div>
<div class="container pb-5"><div class="row justify-content-center"><div class="col-md-5">
  <div class="ahar-card p-4">
    @if(Model.ErrorMessage != null){ <div class="alert alert-danger">@Model.ErrorMessage</div> }
    <form asp-action="VolunteerLogin" method="post">
      <div class="mb-3"><label class="form-label fw-bold">Email</label><input asp-for="Email" class="form-control form-control-lg" placeholder="Email"/></div>
      <div class="mb-3"><label class="form-label fw-bold">Password</label><input asp-for="Password" type="password" class="form-control form-control-lg"/></div>
      <button type="submit" class="btn btn-info text-white w-100 btn-lg"><i class="fa fa-sign-in-alt me-2"></i>Login</button>
    </form>
  </div>
</div></div></div>
