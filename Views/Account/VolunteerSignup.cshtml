@model AharMealsWithLove.Models.SignupViewModel
@{ ViewData["Title"] = "Volunteer Sign Up"; bool otpSent = Model.OtpSent; }
<div class="page-header"><div class="container"><h1><i class="fa fa-hands-helping me-3 text-warning"></i>Volunteer Sign Up</h1></div></div>
<div class="container pb-5"><div class="row justify-content-center"><div class="col-md-5">
  <div class="ahar-card p-4">
    <div class="text-center mb-4"><div class="rounded-circle bg-info d-inline-flex align-items-center justify-content-center mb-3" style="width:70px;height:70px;"><i class="fa fa-hands-helping fa-2x text-white"></i></div><h3 class="fw-bold">Join as Volunteer</h3></div>
    @if(Model.Message != null){ <div class="alert @(Model.Message.Contains("OTP") || Model.Message.Contains("Demo") ? "alert-success" : "alert-danger") mb-3">@Model.Message</div> }
    <form asp-action="VolunteerSignup" method="post">
      <input type="hidden" name="OtpSent" value="@otpSent"/>
      <div class="mb-3"><label class="form-label fw-bold">Email Address</label>
        @if(otpSent){ <input asp-for="Email" class="form-control form-control-lg" readonly/> }
        else { <input asp-for="Email" class="form-control form-control-lg" placeholder="Your email"/> }
      </div>
      @if(otpSent){
        <div class="mb-3"><label class="form-label fw-bold">OTP</label><input asp-for="OTP" class="form-control form-control-lg" placeholder="Enter OTP"/></div>
        <button name="action" value="verifyotp" class="btn btn-info text-white w-100 btn-lg"><i class="fa fa-check me-2"></i>Verify and Register</button>
      } else {
        <button name="action" value="sendotp" class="btn btn-info text-white w-100 btn-lg"><i class="fa fa-paper-plane me-2"></i>Send OTP</button>
      }
      <hr/><p class="text-center text-muted mb-0">Already registered? <a asp-controller="Account" asp-action="VolunteerLogin" class="text-info fw-bold">Login here</a></p>
    </form>
  </div>
</div></div></div>
