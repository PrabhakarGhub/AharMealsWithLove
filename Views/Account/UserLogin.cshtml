@model AharMealsWithLove.Models.LoginViewModel
@{ ViewData["Title"] = "User Login"; }
<div class="page-header"><div class="container"><h1><i class="fa fa-sign-in-alt me-3 text-warning"></i>User Login</h1></div></div>
<div class="container pb-5"><div class="row justify-content-center"><div class="col-md-5">
  <div class="ahar-card p-4">
    <div class="text-center mb-4"><div class="rounded-circle bg-warning d-inline-flex align-items-center justify-content-center mb-3" style="width:70px;height:70px;"><i class="fa fa-user fa-2x text-dark"></i></div><h3 class="fw-bold">User Login</h3></div>
    @if(Model.ErrorMessage != null){ <div class="alert alert-danger">@Model.ErrorMessage</div> }
    <form asp-action="UserLogin" method="post">
      <div class="mb-3"><label class="form-label fw-bold">Email</label><input asp-for="Email" class="form-control form-control-lg" placeholder="Email"/></div>
      <div class="mb-3"><label class="form-label fw-bold">Password</label><input asp-for="Password" type="password" class="form-control form-control-lg" placeholder="Password"/></div>
      <button type="submit" class="btn btn-ahar w-100 btn-lg"><i class="fa fa-sign-in-alt me-2"></i>Login</button>
      <div class="text-center mt-3"><a asp-controller="Account" asp-action="ForgotPassword" class="text-warning">Forgot Password?</a></div>
      <hr/><p class="text-center text-muted mb-0">New user? <a asp-controller="Account" asp-action="UserSignup" class="text-warning fw-bold">Register here</a></p>
    </form>
  </div>
</div></div></div>
