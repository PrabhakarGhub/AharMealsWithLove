@model AharMealsWithLove.Models.AdminLoginViewModel
@{ ViewData["Title"] = "Admin Login"; }
<div class="page-header"><div class="container"><h1><i class="fa fa-shield-alt me-3 text-warning"></i>Admin Login</h1></div></div>
<div class="container pb-5"><div class="row justify-content-center"><div class="col-md-5">
  <div class="ahar-card p-4">
    <div class="text-center mb-3"><i class="fa fa-shield-alt fa-3x text-danger mb-2"></i><h3 class="fw-bold">Admin Access</h3></div>
    @if(Model.ErrorMessage != null){ <div class="alert alert-danger">@Model.ErrorMessage</div> }
    <form asp-action="AdminLogin" method="post">
      <div class="mb-3"><label class="form-label fw-bold">Admin ID</label><input asp-for="AdminId" class="form-control form-control-lg" placeholder="Admin ID"/></div>
      <div class="mb-3"><label class="form-label fw-bold">Password</label><input asp-for="Password" type="password" class="form-control form-control-lg"/></div>
      <button type="submit" class="btn btn-danger w-100 btn-lg"><i class="fa fa-sign-in-alt me-2"></i>Login</button>
    </form>
    <div class="alert alert-info mt-3 small"><i class="fa fa-info-circle me-1"></i>Default: ID = <strong>admin</strong>, Password = <strong>admin123</strong></div>
  </div>
</div></div></div>
