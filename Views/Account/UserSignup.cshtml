@model AharMealsWithLove.Models.SignupViewModel
@{ ViewData["Title"] = "User Sign Up"; bool otpSent = Model.OtpSent; }
<div class="page-header"><div class="container"><h1><i class="fa fa-user-plus me-3 text-warning"></i>User Sign Up</h1></div></div>
<div class="container pb-5"><div class="row justify-content-center"><div class="col-md-5">
  <div class="ahar-card p-4">
    <div class="text-center mb-4">
      <div class="rounded-circle bg-warning d-inline-flex align-items-center justify-content-center mb-3" style="width:70px;height:70px;"><i class="fa fa-user fa-2x text-dark"></i></div>
      <h3 class="fw-bold">Create Account</h3>
    </div>
    @if(Model.Message != null){ <div class="alert @(Model.Message.Contains("OTP") || Model.Message.Contains("Demo") ? "alert-success" : "alert-danger") mb-3">@Model.Message</div> }
    <form asp-action="UserSignup" method="post">
      <input type="hidden" name="OtpSent" value="@otpSent"/>
      <div class="mb-3"><label class="form-label fw-bold">Email Address</label>
        @if(otpSent){ <input asp-for="Email" class="form-control form-control-lg" readonly/> }
        else { <input asp-for="Email" class="form-control form-control-lg" placeholder="Enter your email"/> }
      </div>
      @if(otpSent){
        <div class="mb-3"><label class="form-label fw-bold">Enter OTP</label><input asp-for="OTP" class="form-control form-control-lg" placeholder="Enter OTP sent to email"/></div>
        <button name="action" value="verifyotp" class="btn btn-ahar w-100 btn-lg"><i class="fa fa-check me-2"></i>Verify OTP and Register</button>
      } else {
        <button name="action" value="sendotp" class="btn btn-ahar w-100 btn-lg"><i class="fa fa-paper-plane me-2"></i>Send OTP</button>
      }
      <hr class="my-3"/>
      <p class="text-center text-muted mb-0">Already registered? <a asp-controller="Account" asp-action="UserLogin" class="text-warning fw-bold">Login here</a></p>
    </form>
  </div>
</div></div></div>
