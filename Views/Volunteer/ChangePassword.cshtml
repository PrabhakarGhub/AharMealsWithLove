@model AharMealsWithLove.Models.ChangePasswordViewModel
@{ ViewData["Title"] = "Change Password"; }
<div class="container-fluid"><div class="row">
  @await Html.PartialAsync("_VolSidebar")
  <div class="col-md-10 py-4"><div class="row justify-content-center"><div class="col-md-6">
    <h3 class="fw-bold mb-4"><i class="fa fa-key text-info me-2"></i>Change Password</h3>
    @if(Model.Message != null){ <div class="alert alert-success">@Model.Message</div> }
    <div class="ahar-card p-4">
      <form asp-action="ChangePassword" method="post">
        <div class="mb-3"><label class="form-label fw-bold">Old Password</label><input asp-for="OldPassword" type="password" class="form-control form-control-lg"/></div>
        <div class="mb-3"><label class="form-label fw-bold">New Password</label><input asp-for="Password" type="password" class="form-control form-control-lg"/></div>
        <div class="mb-3"><label class="form-label fw-bold">Confirm</label><input asp-for="ConfirmPassword" type="password" class="form-control form-control-lg"/></div>
        <button type="submit" class="btn btn-info text-white btn-lg w-100"><i class="fa fa-save me-2"></i>Update</button>
      </form>
    </div>
  </div></div></div>
</div></div>
