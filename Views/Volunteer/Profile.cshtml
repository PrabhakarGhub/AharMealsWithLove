@model AharMealsWithLove.Models.ProfileViewModel
@{ ViewData["Title"] = "Volunteer Profile"; }
<div class="container-fluid"><div class="row">
  @await Html.PartialAsync("_VolSidebar")
  <div class="col-md-10 py-4">
    <h3 class="fw-bold mb-4"><i class="fa fa-user text-info me-2"></i>My Profile</h3>
    @if(Model.Message != null){ <div class="alert alert-success">@Model.Message</div> }
    <div class="ahar-card p-4">
      <form asp-action="Profile" method="post" enctype="multipart/form-data">
        <div class="row g-3">
          <div class="col-md-6"><label class="form-label fw-bold">Full Name</label><input asp-for="Name" class="form-control"/></div>
          <div class="col-md-6"><label class="form-label fw-bold">Email</label><input asp-for="Email" class="form-control" readonly/></div>
          <div class="col-md-6"><label class="form-label fw-bold">Gender</label><select asp-for="Gender" class="form-select"><option value="">Select</option><option>Male</option><option>Female</option><option>Other</option></select></div>
          <div class="col-md-6"><label class="form-label fw-bold">DOB</label><input asp-for="DOB" type="date" class="form-control"/></div>
          <div class="col-md-6"><label class="form-label fw-bold">Phone</label><input asp-for="Phone" class="form-control"/></div>
          <div class="col-md-6"><label class="form-label fw-bold">Aadhar</label><input asp-for="Aadhar" class="form-control"/></div>
          <div class="col-12"><label class="form-label fw-bold">Address</label><input asp-for="Address" class="form-control"/></div>
          <div class="col-md-6"><label class="form-label fw-bold">Profile Image</label><input asp-for="Image" type="file" class="form-control"/><input asp-for="ExistingImage" type="hidden"/></div>
          <div class="col-12"><button type="submit" class="btn btn-info text-white btn-lg"><i class="fa fa-save me-2"></i>Update</button></div>
        </div>
      </form>
    </div>
  </div>
</div></div>
