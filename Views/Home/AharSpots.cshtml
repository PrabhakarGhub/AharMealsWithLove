@model List<Dictionary<string, string>>
@{ ViewData["Title"] = "Ahar Spots"; }
<div class="page-header"><div class="container"><h1><i class="fa fa-map-marker-alt me-3 text-warning"></i>Ahar Spots</h1></div></div>
<div class="container pb-5">
  @if(Model != null && Model.Count > 0){
    <div class="row g-3">
      @foreach(var s in Model){
        <div class="col-md-4">
          <div class="ahar-card p-3">
            <div class="d-flex align-items-center mb-2"><i class="fa fa-map-pin text-warning me-2 fa-lg"></i><span class="badge bg-warning text-dark">@s.GetValueOrDefault("category","–")</span></div>
            <p class="fw-bold mb-1">@s.GetValueOrDefault("type","–")</p>
            <p class="text-muted small mb-1"><i class="fa fa-location-arrow me-1"></i>@s.GetValueOrDefault("address","–")</p>
            <p class="text-muted small mb-0"><i class="fa fa-users me-1"></i>~@s.GetValueOrDefault("nopeople","–") people</p>
          </div>
        </div>
      }
    </div>
  } else {
    <div class="alert alert-info text-center"><i class="fa fa-info-circle me-2"></i>No Ahar Spots registered yet. Admin can add spots from the admin panel.</div>
  }
</div>
