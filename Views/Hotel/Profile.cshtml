@model Dictionary<string,string>
@{ ViewData["Title"] = "Hotel Profile"; }
<div class="container-fluid"><div class="row">
  @await Html.PartialAsync("_HotelSidebar")
  <div class="col-md-10 py-4">
    <h3 class="fw-bold mb-4"><i class="fa fa-hotel text-success me-2"></i>Hotel Profile</h3>
    @if(Model != null){
      <div class="ahar-card p-4"><div class="row g-3">
        <div class="col-md-6"><div class="dash-stat"><span class="text-muted small">Hotel ID</span><div class="fw-bold">@Model.GetValueOrDefault("hotelid","–")</div></div></div>
        <div class="col-md-6"><div class="dash-stat"><span class="text-muted small">Name</span><div class="fw-bold">@Model.GetValueOrDefault("Name","–")</div></div></div>
        <div class="col-md-6"><div class="dash-stat"><span class="text-muted small">Email</span><div class="fw-bold">@Model.GetValueOrDefault("Email","–")</div></div></div>
        <div class="col-md-6"><div class="dash-stat"><span class="text-muted small">Contact</span><div class="fw-bold">@Model.GetValueOrDefault("Contact","–")</div></div></div>
        <div class="col-md-6"><div class="dash-stat"><span class="text-muted small">FSSAI</span><div class="fw-bold">@Model.GetValueOrDefault("fssai","–")</div></div></div>
      </div></div>
    } else { <div class="alert alert-warning">Profile not found.</div> }
  </div>
</div></div>
